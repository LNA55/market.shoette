# Copie ce fichier vers deploy.config et remplis les valeurs.
# deploy.config est ignoré par Git (il ne quitte jamais cette machine).
# Authentification : automatique via ~/.netrc.

# Serveur FTP OVH — manager OVH > Web Cloud > Hébergements > shoette.com > onglet FTP-SSH
FTP_HOST="ftp.cluster014.hosting.ovh.net"

# Chemin du répertoire distant, relatif à la racine FTP.
# Garde-fou : doit contenir "market", sinon le script refuse de déployer.
REMOTE_PATH="market"
