# market.shoette.com — redirections
# Renommage des runs Skill 1 avec préfixe s1- (schéma s[K]-[N]_[date], 2026-06-11)
Redirect 301 /apps-perte-de-poids/1_2026-06-11 /apps-perte-de-poids/s1-1_2026-06-11
Redirect 301 /apps-perte-de-poids/2_2026-06-11 /apps-perte-de-poids/s1-2_2026-06-11
# Pages doc : focus-skill → focus-step (2026-06-12), puis focus-step déplacé sous how-it-works/ (2026-06-15)
Redirect 301 /focus-skill-1 /how-it-works/focus-step-1
Redirect 301 /focus-skill-2 /how-it-works/focus-step-2
Redirect 301 /focus-skill-3 /how-it-works/focus-step-3
Redirect 301 /focus-skill-4 /how-it-works/focus-step-4
# Snapshot Step 1 (lien direct historique) — cible spécifique AVANT la redirection de préfixe ci-dessous
Redirect 301 /focus-step-1/skill-1-read-the-market_2026-06-12.md /how-it-works/focus-step-1/process-skill-11juin2026/skill-1-read-the-market_2026-06-12.md
# focus-step-N déplacés sous how-it-works/ (2026-06-15) — le préfixe couvre aussi les sous-pages (process)
Redirect 301 /focus-step-1 /how-it-works/focus-step-1
Redirect 301 /focus-step-2 /how-it-works/focus-step-2
Redirect 301 /focus-step-3 /how-it-works/focus-step-3
Redirect 301 /focus-step-4 /how-it-works/focus-step-4

# market.shoette.com — règles de cache
# Les pages HTML et les data.json évoluent (nouveaux runs, mises à jour Skill 3) :
# toujours revalider auprès du serveur.
<IfModule mod_headers.c>
  <FilesMatch "\.(html|json)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  # Assets versionnés : un changement = un nouveau nom de fichier, donc cache long.
  <FilesMatch "positioning-chart-v[0-9]+\.(js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # Charte des pages parent : cache court (évolue avec le site).
  <FilesMatch "^site\.css$">
    Header set Cache-Control "public, max-age=3600"
  </FilesMatch>
</IfModule>
